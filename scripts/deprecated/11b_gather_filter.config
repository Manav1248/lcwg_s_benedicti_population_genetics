#!/bin/bash
# 11b_gather_filter.config - gather chunks and hard-filter variants

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export BCFTOOLS_SIF=${CONT}/staphb_bcftools:1.17.sif
export BCFTOOLS_FIX_THREADS=2
export BCFTOOLS_VIEW_THREADS=4
export BCFTOOLS_MAX_PARALLEL=4

# GATK hard-filter thresholds
export SNP_FILTER="QD<2.0 || FS>60.0 || MQ<40.0 || MQRankSum<-12.5 || ReadPosRankSum<-8.0 || SOR>3.0"
export INDEL_FILTER="QD<2.0 || FS>200.0 || ReadPosRankSum<-20.0 || SOR>10.0"
