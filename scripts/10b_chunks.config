#!/bin/bash
# 10b_chunks.config - shared config for 10Mb chunked GenomicsDBImport + GenotypeGVCFs

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

# import (GenomicsDBImport) resources
export JOB10B_IMPORT_NAME="genomicsdb_chunk"
export JOB10B_IMPORT_CPUS=4
export JOB10B_IMPORT_TIME="4:00"
export JOB10B_IMPORT_MEMORY="24GB"
export JOB10B_IMPORT_HEAP="-Xmx20G"

# genotype (GenotypeGVCFs) resources
export JOB10B_GENO_NAME="genotype_chunk"
export JOB10B_GENO_CPUS=2
export JOB10B_GENO_TIME="6:00"
export JOB10B_GENO_MEMORY="16GB"
export JOB10B_GENO_HEAP="-Xmx14G"

export CHUNK_SIZE=10000000
