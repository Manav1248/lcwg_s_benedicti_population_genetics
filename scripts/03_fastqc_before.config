#!/bin/bash
# 03_fastqc_before.config - FastQC Before Trimming

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export FASTQC_BEFORE=$WORKING_DIR/03_FASTQC_BEFORE
export FASTQC_LOGS_O=$FASTQC_BEFORE/out
export FASTQC_LOGS_E=$FASTQC_BEFORE/err
export FASTQC_B_HTML=$FASTQC_BEFORE/htmls

export JOB3_NAME="03_fastqc_before"
export JOB3_CPUS=4
export JOB3_MEMORY="2GB"
export JOB3_TIME="00:30"
