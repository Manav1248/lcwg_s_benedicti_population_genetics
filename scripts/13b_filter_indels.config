#!/bin/bash
# 13b_filter_indels.config - hard-filter indels

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export JOB13B_NAME="filter_indels"
export JOB13B_CPUS=4
export JOB13B_TIME="2:00"
export JOB13B_MEMORY="8GB"
export INDEL_LOGS_O=${GENOTYPED_DIR}/indel_out
export INDEL_LOGS_E=${GENOTYPED_DIR}/indel_err

export BCFTOOLS_VIEW_THREADS=4
export INDEL_FILTER="QD<2.0 || FS>200.0 || ReadPosRankSum<-20.0 || SOR>10.0"
