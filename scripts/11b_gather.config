#!/bin/bash
# 11b_gather.config - fix chunk VCFs and concatenate into all-sites VCF

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export JOB11B_NAME="gather"
export JOB11B_CPUS=8
export JOB11B_TIME="12:00"
export JOB11B_MEMORY="24GB"
export GATHER_LOGS_O=${GENOTYPED_DIR}/gather_out
export GATHER_LOGS_E=${GENOTYPED_DIR}/gather_err

export BCFTOOLS_FIX_THREADS=2
export BCFTOOLS_MAX_PARALLEL=4
