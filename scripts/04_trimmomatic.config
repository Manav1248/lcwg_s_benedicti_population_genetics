#!/bin/bash
# 04_trimmomatic.config - Adapter Trimming & Quality Filtering

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export TRIM_LOGS_O=$TRIM_DIR/out
export TRIM_LOGS_E=$TRIM_DIR/err

# Trimmomatic parameters
export TRIM_ILLUMINACLIP="2:30:10"    # seed mismatches:palindrome:simple
export TRIM_SLIDINGWINDOW="4:20"      # window:quality (Phred 20 cutoff)
export TRIM_MINLEN="50"               # shorter min than metagenomics...
export TRIM_HEADCROP="0"              # set >0 if FastQC shows bad leading bases

export JOB4_NAME="04_trimmomatic"
export JOB4_CPUS=8
export JOB4_MEMORY="8GB"
export JOB4_TIME="02:00"
export JOB4_JAVA_HEAP="-Xmx6G"
export JOB4_PHRED="phred33"
