#!/bin/bash
# 09b_genomicsdb_import.config - GenomicsDBImport per chromosome

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export JOB09B_NAME="genomicsdb_import"
export JOB09B_CPUS=5
export JOB09B_TIME="24:00"
export JOB09B_MEMORY="32GB"
export JOB09B_HEAP="-Xmx28G"
export JOB09B_GC_THREADS=2
export JOB09B_READER_THREADS=5
export JOB09B_BATCH_SIZE=50

export GENOMICSDB_DIR=${WORKING_DIR}/09b_GENOMICSDB
export GENOMICSDB_LOGS_O=${GENOMICSDB_DIR}/out
export GENOMICSDB_LOGS_E=${GENOMICSDB_DIR}/err
