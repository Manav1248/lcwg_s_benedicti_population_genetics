#!/bin/bash
# 07_bam_qc.config

# pulls the dir where the local config file is. i.e, has to be in the same dir as global_config
source "$(dirname "${BASH_SOURCE[0]}")/global_config.sh"

export JOB_NAME="07_bam_qc"
export JOB_CPUS=4
export JOB_TIME="04:00"   # HH:MM — runs both tools on both BAM sets
export JOB_MEMORY="8GB"   # Qualimap Java heap needs ~4-6GB

export BAM_QC=${BAM_QC_DIR}   # from global config, keeps intermediate path references clean
export BAM_QC_LOGS_O=${BAM_QC}/out
export BAM_QC_LOGS_E=${BAM_QC}/err

# Qualimap settings
export QUALIMAP_JAVA_MEM="6G"
export QUALIMAP_THREADS=${JOB_CPUS}

# mosdepth settings
export MOSDEPTH_WINDOW=50000
export MOSDEPTH_THREADS=${JOB_CPUS}

# Output subdirectories
export QC_ANGSD_QUALIMAP=${BAM_QC}/angsd/qualimap
export QC_ANGSD_MOSDEPTH=${BAM_QC}/angsd/mosdepth
export QC_GATK_QUALIMAP=${BAM_QC}/gatk/qualimap
export QC_GATK_MOSDEPTH=${BAM_QC}/gatk/mosdepth
