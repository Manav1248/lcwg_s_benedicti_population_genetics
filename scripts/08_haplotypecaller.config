#!/bin/bash
# 08_haplotypecaller.config - GATK HaplotypeCaller in GVCF mode
source "$(dirname "${BASH_SOURCE[0]}")/global_config.sh"

export JOB8_NAME="haplotypecaller"
export JOB8_CPUS=2
export JOB8_TIME="12:00"
export JOB8_MEMORY="12GB"
export JOB8_CONCURRENT=50

# per-interval fallback (08_haplotypecaller_by_interval.sh)
export JOB8_INT_CPUS=6
export JOB8_INT_TIME="12:00"
export JOB8_INT_MEMORY="12GB"
export JOB8_MERGE_TIME="2:00"
export JOB8_MERGE_MEMORY="8GB"

export GATK_SIF=${CONT}/broadinstitute_gatk:4.6.0.0.sif

export GATK_BAM_DIR=${WORKING_DIR}/05_BWA_MEM2/gatk_downstream

export HC_DIR=${WORKING_DIR}/08_HAPLOTYPECALLER
export GVCF_DIR=${HC_DIR}/gvcfs
export HC_LOGS_O=${HC_DIR}/out
export HC_LOGS_E=${HC_DIR}/err

export REF_DIR=$(dirname "$REFERENCE")
