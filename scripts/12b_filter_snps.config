#!/bin/bash
# 12b_filter_snps.config - hard-filter SNPs

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)" || true
[[ -z "$SCRIPT_DIR" || ! -f "${SCRIPT_DIR}/global_config.sh" ]] && SCRIPT_DIR="${PIPELINE_DIR}"
source "${SCRIPT_DIR}/global_config.sh"

export JOB12B_NAME="filter_snps"
export JOB12B_CPUS=4
export JOB12B_TIME="2:00"
export JOB12B_MEMORY="8GB"
export SNP_LOGS_O=${GENOTYPED_DIR}/snp_out
export SNP_LOGS_E=${GENOTYPED_DIR}/snp_err

export BCFTOOLS_VIEW_THREADS=4
export SNP_FILTER="QD<2.0 || FS>60.0 || MQ<40.0 || MQRankSum<-12.5 || ReadPosRankSum<-8.0 || SOR>3.0"
