#!/bin/bash
# 05b_bwamem2_gatk.config
source "$(dirname "${BASH_SOURCE[0]}")/global_config.sh"

export JOB5B_NAME="bwa_gatk"
export JOB5B_CPUS=8
export JOB5B_TIME="04:00"
export JOB5B_MEMORY="12GB"

export BWAMEM2_SIF=${WORKING_DIR}/containers/bwa-mem2:2.2.1--hd03093a_5
