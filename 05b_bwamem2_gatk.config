export ALIGN_GATK_DIR=${WORKING_DIR}/05_BWA_MEM2/gatk_downstream
export ALIGN_GATK_LOGS_O=${ALIGN_GATK_DIR}/out
export ALIGN_GATK_LOGS_E=${ALIGN_GATK_DIR}/err
